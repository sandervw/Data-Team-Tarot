---
import { Image } from 'astro:assets';

interface Props {
  readonly card: {
    readonly name: string;
    readonly numeral: string;
    readonly art: string;
  };
}

const { card } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/cards/*.{jpeg,jpg,png,gif,webp,png}');
const artPath = `/src/assets/cards/${card.art}`;
const hasArt = artPath in images;
---
<div class="tarot-card">
  <p class="tarot-numeral">{card.numeral}</p>
  {hasArt ? (
    <Image src={images[artPath]()} alt={card.name} class="tarot-art" />
  ) : (
    <div class="tarot-art-placeholder">
      <span class="tarot-numeral">{card.numeral}</span>
    </div>
  )}
  <h2 class="tarot-name">{card.name}</h2>
</div>

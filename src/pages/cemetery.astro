---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { PriorDraws } from "../components/PriorDraws";

const fortuneEntries = await getCollection("fortunes");
const cardEntries = await getCollection("cards");
const fortunes = fortuneEntries.map((entry) => entry.data);
const cards = cardEntries.map((entry) => ({ ...entry.data, id: entry.id }));
---

<BaseLayout title="Cemetery of Fortunes Past - Standup Fortunes">
  <h1 class="title">Cemetery of Fortunes Past</h1>
  <PriorDraws fortunes={fortunes} cards={cards} client:only="react" />
</BaseLayout>

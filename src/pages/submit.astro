---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { SubmissionForm } from "../components/SubmissionForm";

const cardEntries = await getCollection("cards");
const cards = cardEntries
  .sort((a, b) => a.data.number - b.data.number)
  .map((entry) => ({
    id: entry.id,
    name: entry.data.name,
    numeral: entry.data.numeral,
    art: entry.data.art,
  }));
---

<BaseLayout title="Deliver a Fortune">
  <h1 class="title">Deliver a Fortune</h1>
  <SubmissionForm cards={cards} client:only="react" />
</BaseLayout>

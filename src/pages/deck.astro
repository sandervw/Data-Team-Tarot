---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Card } from "../components/Card";
import { getCollection } from "astro:content";

const allCards = await getCollection("cards");
const sorted = allCards.toSorted((a, b) => a.data.number - b.data.number);
---

<BaseLayout title="Card Deck - Standup Fortunes">
  <h1 class="title">The Major Schemata</h1>
  <p class="subtitle">22 cards. Infinite excuses.</p>

  <div class="deck-grid">
    {sorted.map((card) => <Card card={card.data} client:only="react" />)}
  </div>
</BaseLayout>

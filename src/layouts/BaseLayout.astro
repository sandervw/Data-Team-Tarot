---
interface Props {
  title?: string;
}

const { title = "Data Team Tarot" } = Astro.props;
---

<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="site-title">Data Team Tarot</a>
    </header>

    <main class="stage">
      <slot />
    </main>

    <footer class="site-footer">
      <p>The cards know. The sprint board does not.</p>
    </footer>
  </body>
</html>

<style is:global>
  @import "../styles/sparse.css";
  @import "../styles/tarot.css";
</style>
